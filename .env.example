# Slack bot runtime secrets. Copy to `.env`, fill in, and `chmod 600 .env`.
# See docs/DEPLOY.md for where to obtain each value.

# Anthropic API key for the Claude Agent SDK.
# Format: sk-ant-...
# Source: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Slack bot user OAuth token.
# Format: xoxb-...
# Source: https://api.slack.com/apps → <your app> → OAuth & Permissions
SLACK_BOT_TOKEN=

# Slack app-level token for Socket Mode (scope: connections:write).
# Format: xapp-...
# Source: https://api.slack.com/apps → <your app> → Basic Information → App-Level Tokens
SLACK_APP_TOKEN=

# Supabase Personal Access Token used as a Bearer credential for the hosted MCP server.
# Format: opaque string
# Source: https://supabase.com/dashboard/account/tokens
SUPABASE_MCP_TOKEN=

# Optional — scope the Supabase MCP server to a single project.
# Unset = the token operates across every project it can see.
# Source: the `<ref>` in https://supabase.com/dashboard/project/<ref>
# SUPABASE_PROJECT_REF=

# Node runtime mode. Leave as "production" on the VPS.
NODE_ENV=production

# Logger verbosity: debug | info | warn | error. Default is info.
LOG_LEVEL=info

# Optional — working directory the Agent SDK uses as the agent's scratch dir.
# Default is /home/botuser/agent-workdir (the VPS path). Override locally to
# a path that exists on your laptop, e.g. ./agent-workdir or /tmp/agent-workdir.
# AGENT_WORKDIR=

# Optional — Claude model the agent uses. Unset = SDK default (Sonnet).
# Examples: claude-opus-4-7, claude-sonnet-4-5, opus, sonnet, haiku.
# Opus is ~5x the cost of Sonnet per token.
# AGENT_MODEL=
